+static int random_index(int limit) {
+    if (limit <= 0) {
+        return 0;
+    }
+
+    int bucket_size = RAND_MAX / limit;
+    int threshold = bucket_size * limit;
+    int value;
+
+    do {
+        value = rand();
+    } while (value >= threshold);
+
+    return value / bucket_size;
+}
